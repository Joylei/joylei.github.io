&lt;&#x2F;span&gt;&lt;span style=&quot;color:#82aaff;&quot;&gt;sudo make install&lt;&#x2F;span&gt;&lt;span style=&quot;color:#eeffff;&quot;&gt;
&lt;&#x2F;span&gt;&lt;&#x2F;pre&gt;
